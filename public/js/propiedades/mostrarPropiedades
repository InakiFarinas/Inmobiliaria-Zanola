
document.addEventListener('DOMContentLoaded', function(){

    mostrarPropiedades();


});

function mostrarPropiedades() {

    const respuesta = fetch('mostrarPropiedades.php')
    
    resTexto = respuesta.texto()

    let jsonTexto = JSON.parse(resTexto)

    const {htmlapi} = jsonTexto 
        document.getElementById('mostrarPropiedades').innerHTML = 
        map =(item => 

            `<li>
                      id_propiedad: ${id_propiedad} <br>
                        calle:  ${calle} <br>
                        altura: ${altura} <br>
                        precio: ${precio} <br>
                        estado: ${estado} <br>
                        tipo: ${tipo} <br>
                        ambientes: ${ambientes} <br>
                        garaje: ${garaje} <br>
                        baños: ${baños} <br>
                        descripcion: ${descripcion} <br>
                        fecha_publicacion: ${fecha_publicacion} <br>
                        id_ciudad: ${id_ciudad}
            </li>`

        )
            .join('');
} 

